  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading Font",
        "default": "playfair_display_n4"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body Font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "font_size",
        "label": "Base Font Size (Desktop)",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "heading_text_transform",
        "label": "Heading Text Case",
        "options": [
          { "value": "none", "label": "Normal" },
          { "value": "uppercase", "label": "Uppercase" },
          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "none"
      }
    ]
  },
  {
    "name": "Global Layout",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo Image",
        "info": "Used globally as the brand logo."
      },
      {
        "type": "range",
        "id": "container_width",
        "label": "Container Max Width",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "default": 1400,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "button_border_radius",
        "label": "Button Corners",
        "options": [
          { "value": "0", "label": "Square" },
          { "value": "4px", "label": "Rounded" },
          { "value": "30px", "label": "Pill" }
        ],
        "default": "0"
      }
    ]
  },
  {
    "name": "Spacing",
    "settings": [
      {
        "type": "range",
        "id": "section_spacing_desktop",
        "label": "Section Vertical Spacing (Desktop)",
        "min": 40,
        "max": 120,
        "step": 10,
        "default": 80,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_spacing_mobile",
        "label": "Section Vertical Spacing (Mobile)",
        "min": 20,
        "max": 80,
        "step": 10,
        "default": 48,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "grid_gap",
        "label": "Grid Column Gap",
        "min": 8,
        "max": 40,
        "step": 2,
        "default": 32,
        "unit": "px",
        "info": "Space between columns in section grids (featured collections, room collections, etc.)."
      }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_secondary_image_on_hover",
        "label": "Show Secondary Image on Hover",
