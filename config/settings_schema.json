        "default": "slider"
      },
      {
        "type": "checkbox",
        "id": "enable_image_zoom",
        "label": "Enable Image Zoom",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_sticky_cart",
        "label": "Enable Sticky Add to Cart",
        "default": true
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart Action Behavior",
        "options": [
          { "value": "drawer", "label": "Slideout Drawer" },
          { "value": "modal", "label": "Modal Popup" },
          { "value": "page", "label": "Standard Cart Page" }
        ],
        "default": "drawer"
      }
    ]
  },
  {
    "name": "Quick View",
    "settings": [
      {
        "type": "select",
        "id": "quickview_type",
        "label": "Quick View Mode",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "modal", "label": "Modal Popup" },
          { "value": "none", "label": "Disabled" }
