      },
      {
        "type": "checkbox",
        "id": "show_vendor",
        "label": "Show Brand/Vendor",
        "default": false
      },
      {
        "type": "select",
        "id": "card_badge_style",
        "label": "Badge Style",
        "options": [
          { "value": "pill", "label": "Pill" },
          { "value": "square", "label": "Square" }
        ],
        "default": "square"
      },
      {
        "type": "checkbox",
        "id": "enable_quick_add",
        "label": "Enable Quick Add to Cart",
        "default": true
      }
    ]
  },
  {
    "name": "Product Pages",
    "settings": [
      {
        "type": "select",
        "id": "product_gallery_layout",
        "label": "Gallery Layout",
        "options": [
          { "value": "stacked", "label": "Stacked List" },
          { "value": "grid", "label": "2-Column Grid" },
          { "value": "slider", "label": "Slider" }
