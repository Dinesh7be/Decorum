  {
    "name": "Branding",
    "settings": [
      {
        "type": "header",
        "content": "Logo"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo",
        "info": "Shown in the header and password page. SVG or PNG recommended."
      },
      {
        "type": "image_picker",
        "id": "logo_mobile",
        "label": "Mobile logo (optional)",
        "info": "Used on small screens. Falls back to the main logo if empty."
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 40,
        "max": 300,
        "step": 5,
        "unit": "px",
        "label": "Logo width (desktop)",
        "default": 120
      },
      {
        "type": "range",
        "id": "logo_width_mobile",
        "min": 30,
        "max": 200,
        "step": 5,
        "unit": "px",
        "label": "Logo width (mobile)",
        "default": 80
      },
      {
        "type": "header",
        "content": "Favicon"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Shown in browser tabs. Square image, at least 32x32px."
      },
      {
        "type": "header",
        "content": "Brand colors"
      },
      {
        "type": "paragraph",
        "content": "These map to your primary brand palette and appear across the storefront."
      },
      {
        "type": "color",
        "id": "accent_color",
        "label": "Primary / brand color",
        "default": "#2B2927"
      },
      {
        "type": "color",
        "id": "secondary_accent",
        "label": "Secondary brand color",
        "default": "#8C7D70"
