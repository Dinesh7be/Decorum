  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "label": "Heading font",
        "default": "playfair_display_n4"
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "header",
        "content": "Base size & spacing"
      },
      {
        "type": "range",
        "id": "font_size",
        "label": "Base font size",
        "min": 14,
        "max": 20,
        "step": 1,
        "default": 16,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "body_line_height",
        "label": "Body line height",
        "min": 120,
        "max": 200,
        "step": 5,
        "default": 160,
        "unit": "%",
        "info": "160% equals 1.6 line height."
      },
      {
        "type": "range",
        "id": "heading_line_height",
        "label": "Heading line height",
        "min": 100,
        "max": 160,
        "step": 5,
        "default": 125,
        "unit": "%"
      },
      {
        "type": "range",
        "id": "body_letter_spacing",
        "label": "Body letter spacing",
        "min": -1,
        "max": 4,
        "step": 0.5,
        "default": 0,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "heading_letter_spacing",
        "label": "Heading letter spacing",
        "min": -2,
        "max": 8,
        "step": 0.5,
        "default": 0,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "heading_text_transform",
        "label": "Heading text case",
        "options": [
          { "value": "none", "label": "As typed" },
          { "value": "uppercase", "label": "Uppercase" },
          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "none"
      },
      {
        "type": "header",
        "content": "Heading sizes"
      },
      {
        "type": "range",
        "id": "heading_size_h1",
        "label": "H1 size",
        "min": 28,
        "max": 72,
        "step": 2,
        "default": 40,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "heading_size_h2",
        "label": "H2 size",
        "min": 22,
        "max": 56,
        "step": 2,
        "default": 32,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "heading_size_h3",
        "label": "H3 size",
        "min": 18,
        "max": 40,
        "step": 2,
        "default": 24,
        "unit": "px"
      },
      {
        "type": "header",
        "content": "Button text"
      },
      {
        "type": "range",
        "id": "button_font_size",
        "label": "Button font size",
        "min": 11,
        "max": 18,
        "step": 1,
        "default": 14,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "button_text_transform",
        "label": "Button text style",
        "options": [
          { "value": "none", "label": "As typed" },
          { "value": "uppercase", "label": "Uppercase" },
          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "uppercase"
      },
      {
        "type": "range",
        "id": "button_letter_spacing",
        "label": "Button letter spacing",
        "min": 0,
        "max": 4,
        "step": 0.5,
        "default": 1,
        "unit": "px"
      },
      {
        "type": "select",
        "id": "button_font_weight",
        "label": "Button font weight",
        "options": [
          { "value": "400", "label": "Regular" },
          { "value": "500", "label": "Medium" },
          { "value": "600", "label": "Semibold" },
          { "value": "700", "label": "Bold" }
        ],
        "default": "600"
      }
    ]
  },
