  {
    "name": "Header Settings",
    "settings": [
      {
        "type": "header",
        "content": "Logo Settings"
      },
      {
        "type": "image_picker",
        "id": "header_logo",
        "label": "Logo Image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 50,
        "max": 300,
        "step": 5,
        "unit": "px",
        "label": "Custom Logo Width (Desktop)",
        "default": 120
