{% comment %}
snippets/onboard-collection.liquid

Renders a placeholder collection card in the theme editor when no collection is selected.

Accepts:
- index:         {Number} The index of the placeholder item (optional, defaults to 1)

Usage:
{% render 'onboard-collection', index: forloop.index %}
{% endcomment %}

{%- liquid
  assign placeholder_index = index | default: 1
  assign svg_num = placeholder_index | modulo: 6
  if svg_num == 0
    assign svg_num = 6
  endif
  assign svg_name = 'collection-' | append: svg_num

  assign aspect = aspect_ratio | default: '1:1'
  if aspect == '4:3'
    assign aspect_padding = 75
  else
    assign aspect_padding = 100
  endif
-%}

<div class="collection-card__wrapper">
  <div class="collection-card__image-container" style="padding-bottom: {{ aspect_padding }}%; position: relative; width: 100%; height: 0;">
    <div class="collection-card__image-placeholder" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
      {{ svg_name | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  </div>
</div>
