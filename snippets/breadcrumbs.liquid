{% comment %}
snippets/breadcrumbs.liquid
Renders navigation breadcrumbs trail for collections, products, blogs, and static pages.
{% endcomment %}

{%- unless template == 'index' or template == 'cart' or template == 'list-collections' or template == '404' -%}
  {%- assign t = template | split: '.' | first -%}
  <nav class="breadcrumbs" role="navigation" aria-label="{{ 'general.breadcrumbs.label' | t }}" style="padding: 2rem 0; font-size: var(--font-size-xs); text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-color-light);">
    <ol style="display: flex; gap: 0.8rem; list-style: none; padding: 0; margin: 0; align-items: center;">
      <li>
        <a href="{{ routes.root_url }}" title="{{ 'general.breadcrumbs.home' | t }}" style="color: var(--text-color-light);">{{ 'general.breadcrumbs.home' | t }}</a>
      </li>
      <li style="color: var(--border-color);">&rsaquo;</li>
      
      {%- case t -%}
        {%- when 'page' -%}
          <li>
            <a href="{{ page.url }}" aria-current="page">{{ page.title }}</a>
          </li>
        {%- when 'product' -%}
          {%- if collection.url -%}
            <li>
              <a href="{{ collection.url }}">{{ collection.title }}</a>
            </li>
            <li style="color: var(--border-color);">&rsaquo;</li>
          {%- endif -%}
          <li>
            <a href="{{ product.url }}" aria-current="page">{{ product.title }}</a>
          </li>
        {%- when 'collection' and collection.handle -%}
          {%- if current_tags -%}
            {%- capture url -%}/collections/{{ collection.handle }}{%- endcapture -%}
            <li>{{ collection.title | link_to: url }}</li>
            <li style="color: var(--border-color);">&rsaquo;</li>
            <li>
              <span aria-current="page">{{ current_tags | join: " + " }}</span>
            </li>
          {%- else -%}
            <li>
              <a href="{{ collection.url }}" aria-current="page">{{ collection.title }}</a>
            </li>
          {%- endif -%}
        {%- when 'blog' -%}
          {%- if current_tags -%}
            <li>{{ blog.title | link_to: blog.url }}</li>
            <li style="color: var(--border-color);">&rsaquo;</li>
            <li>
              <span aria-current="page">{{ current_tags | join: " + " }}</span>
            </li>
          {%- else -%}
            <li>
              <a href="{{ blog.url }}" aria-current="page">{{ blog.title }}</a>
            </li>
          {%- endif -%}
        {%- when 'article' -%}
          <li>{{ blog.title | link_to: blog.url }}</li>
          <li style="color: var(--border-color);">&rsaquo;</li>
          <li>
            <a href="{{ article.url }}" aria-current="page">{{ article.title }}</a>
          </li>
        {%- else -%}
          <li>
            <a href="{{ request.path }}" aria-current="page">{{ page_title }}</a>
          </li>
      {%- endcase -%}
    </ol>
  </nav>
{%- endunless -%}
