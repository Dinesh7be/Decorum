{{ 'section-hero-banner.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %}
sections/hero-banner.liquid
{% endcomment %}

{%- liquid
  assign image = section.settings.image
  assign height = section.settings.height
  assign alignment = section.settings.alignment
  assign full_width = section.settings.full_width
  assign text_align = 'left'
  if alignment == 'center'
    assign text_align = 'center'
  elsif alignment == 'right'
    assign text_align = 'right'
  endif

  # Calculate loading strategy based on page index
  assign loading = 'lazy'
  assign fetch_priority = 'auto'
  if section.index == 1
    assign loading = 'eager'
    assign fetch_priority = 'high'
  endif
-%}

<section 
  id="hero-banner--{{ section.id }}"
  class="hero-banner hero-banner--{{ height }} {% if full_width %}hero-banner--full-bleed{% endif %}"
  data-section-id="{{ section.id }}"
  data-section-type="hero-banner"
>
  <!-- Background Image -->
  <div class="hero-banner__image">
    {%- if image != blank -%}
      {{ image | image_url: width: 2000 | image_tag:
        widths: '375, 550, 750, 1100, 1500, 1780, 2000',
        sizes: '100vw',
        loading: loading,
        fetchpriority: fetch_priority,
        class: 'hero-img'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg hero-img' }}
    {%- endif -%}
  </div>

  <!-- Dark Overlay -->
  <div class="hero-banner__overlay"></div>

  <!-- Content Container -->
  <div class="hero-banner__container grid__wrapper">
    <div class="span-12 hero-banner__grid-row">
      <div class="hero-banner__content">
        {%- liquid
          assign banner_title = section.settings.title
          assign is_contextual = false
          if banner_title == blank
            assign is_contextual = true
            if template contains 'collection'
              assign banner_title = collection.title
            elsif template contains 'product'
              assign banner_title = product.title
            elsif template contains 'page'
              assign banner_title = page.title
            elsif template contains 'blog'
              assign banner_title = blog.title
            elsif template contains 'article'
              assign banner_title = article.title
            elsif template contains 'search'
              assign banner_title = 'general.search.search' | t
            elsif template contains 'cart'
              assign banner_title = 'cart.title' | t
            elsif template contains '404'
              assign banner_title = 'general.404.title' | t
            elsif template contains 'list-collections'
              assign banner_title = 'collections.general.all_collections' | t
            endif
          endif
        -%}
        {%- if banner_title != blank -%}
          {%- if is_contextual -%}
            <h1>{{ banner_title | escape }}</h1>
          {%- else -%}
            <h2>{{ banner_title | escape }}</h2>
          {%- endif -%}
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <div class="hero-banner__subheading">{{ section.settings.subheading | escape }}</div>
        {%- endif -%}

        {%- if section.settings.link_text != blank or section.settings.link_text_2 != blank -%}
          <div class="hero-banner__buttons">
            {%- if section.settings.link_text != blank -%}
              <a href="{{ section.settings.link | default: routes.all_products_collection_url }}" class="btn">
                {{ section.settings.link_text | escape }}
              </a>
            {%- endif -%}
            {%- if section.settings.link_text_2 != blank -%}
              <a href="{{ section.settings.link_2 | default: '/pages/contact' }}" class="btn btn--secondary">
                {{ section.settings.link_text_2 | escape }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #hero-banner--{{ section.id }} {
    --hero-text-color: {{ section.settings.text_color | default: '#FFFFFF' }};
    --hero-content-max-width: {{ section.settings.content_max_width | default: 600 }}px;
  }
  #hero-banner--{{ section.id }} .hero-banner__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
  #hero-banner--{{ section.id }} .hero-banner__grid-row {
    display: flex;
    justify-content: {% if alignment == 'center' %}center{% elsif alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    text-align: {{ text_align }};
  }
  #hero-banner--{{ section.id }} .hero-banner__buttons {
    justify-content: {% if alignment == 'center' %}center{% elsif alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
  }
</style>

{% schema %}
{
  "name": "Hero banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Timeless Furniture for Modern Living"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our curated collection of solid oak chairs, textured linen sofas, and architectural lighting."
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full_screen", "label": "Full Screen" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "%",
      "label": "Overlay Dark Density"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading & Button Text Color",
      "default": "#FFFFFF",
      "info": "Switch to a dark color if using a light overlay/image."
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 900,
      "step": 50,
      "default": 600,
      "unit": "px",
      "label": "Content Max Width"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full Bleed Width",
      "default": true
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Primary Button Text",
      "default": "Shop New Arrivals"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "link_text_2",
      "label": "Secondary Button Text",
      "default": "Book Design Consultation"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
