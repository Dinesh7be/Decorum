{{ 'section-design-style-quiz.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %}
sections/design-style-quiz.liquid

Original interactive quiz section. Each "question" block offers up to 4
answers, each tagged with a style key (scandinavian/mid_century/boho/
industrial). Each "result" block defines the copy + collection shown when
that style scores highest. All state/scoring runs client-side in
decor-style-quiz (theme.js) — no answer content ever needs a server round trip.
{% endcomment %}

{%- liquid
  assign space_class = ''
  if section.settings.section_space == 'top'
    assign space_class = ' mt0'
  elsif section.settings.section_space == 'bottom'
    assign space_class = ' mb0'
  elsif section.settings.section_space == 'none'
    assign space_class = ' my0'
  endif

  assign question_blocks = section.blocks | where: 'type', 'question'
  assign result_blocks = section.blocks | where: 'type', 'result'
-%}

<section
  class="global__section{{ space_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="design-style-quiz"
>
  <div class="grid__wrapper">
    <div class="span-8 push-2 sm-span-12">
      {%- if section.settings.title != blank -%}
        <h2 class="section__title" style="text-align: center; margin-bottom: 1rem;">
          {{ section.settings.title | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p style="text-align: center; color: var(--text-color-light); margin-bottom: 3rem;">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

      {%- if question_blocks.size > 0 and result_blocks.size > 0 -%}
        {%- capture progress_template -%}
          {{ 'sections.style_quiz.question_progress' | t: current: '{current}', total: '{total}' }}
        {%- endcapture -%}
        <decor-style-quiz class="style-quiz">
          <div
            class="style-quiz__progress js-quiz-progress"
            aria-live="polite"
            data-template="{{ progress_template | strip | escape }}"
          >
            {{ 'sections.style_quiz.question_progress' | t: current: 1, total: question_blocks.size }}
          </div>

          <form class="style-quiz__track js-quiz-track">
            {%- for block in question_blocks -%}
              <fieldset
                class="style-quiz__question"
                data-question-index="{{ forloop.index0 }}"
                {% if forloop.first %}data-active="true"{% endif %}
                {{ block.shopify_attributes }}
              >
                <legend>{{ block.settings.question | escape }}</legend>
                <ul class="style-quiz__options">
                  {%- for i in (1..4) -%}
                    {%- liquid
                      case i
                        when 1
                          assign option_text = block.settings.option_1_text
                          assign option_style = block.settings.option_1_style
                        when 2
                          assign option_text = block.settings.option_2_text
                          assign option_style = block.settings.option_2_style
                        when 3
                          assign option_text = block.settings.option_3_text
                          assign option_style = block.settings.option_3_style
                        when 4
                          assign option_text = block.settings.option_4_text
                          assign option_style = block.settings.option_4_style
                      endcase
                    -%}
                    {%- if option_text != blank -%}
                      <li>
                        <button type="button" class="style-quiz__option-btn js-quiz-option" data-style="{{ option_style }}">
                          {{ option_text | escape }}
                        </button>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </fieldset>
            {%- endfor -%}
          </form>

          <div class="style-quiz__nav">
            <button type="button" class="btn btn--secondary btn--sm js-quiz-back" hidden>
              {{ 'sections.style_quiz.back' | t }}
            </button>
            <button type="button" class="btn btn--secondary btn--sm js-quiz-restart" hidden>
              {{ 'sections.style_quiz.restart' | t }}
            </button>
          </div>

          <div class="style-quiz__results js-quiz-results">
            {%- for block in result_blocks -%}
              {%- assign result_collection = collections[block.settings.collection] -%}
              <div class="style-quiz__result" data-result-style="{{ block.settings.style_key }}" {{ block.shopify_attributes }}>
                <h3 class="style-quiz__result-title">{{ block.settings.title | escape }}</h3>
                <p class="style-quiz__result-desc">{{ block.settings.description | escape }}</p>
                {%- if result_collection != blank -%}
                  <a href="{{ result_collection.url }}" class="btn">
                    {{ 'sections.style_quiz.shop_style' | t: style: block.settings.title }}
                  </a>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        </decor-style-quiz>
      {%- else -%}
        <p style="text-align: center; color: var(--text-color-light);">
          {{ 'sections.style_quiz.onboarding_notice' | t }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Design style quiz",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Find Your Design Style"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Answer a few questions and we'll match you to a curated collection."
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section Spacing",
      "options": [
        { "value": "top", "label": "No top padding" },
        { "value": "bottom", "label": "No bottom padding" },
        { "value": "both", "label": "Standard padding" },
        { "value": "none", "label": "No padding" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question Text",
          "default": "Which color palette speaks to you?"
        },
        {
          "type": "text",
          "id": "option_1_text",
          "label": "Option 1 Label",
          "default": "Warm neutrals & natural wood"
        },
        {
          "type": "select",
          "id": "option_1_style",
          "label": "Option 1 Maps To",
          "options": [
            { "value": "scandinavian", "label": "Scandinavian" },
            { "value": "mid_century", "label": "Mid-Century" },
            { "value": "boho", "label": "Boho" },
            { "value": "industrial", "label": "Industrial" }
          ],
          "default": "scandinavian"
        },
        {
          "type": "text",
          "id": "option_2_text",
          "label": "Option 2 Label",
          "default": "Rich walnut & bold geometry"
        },
        {
          "type": "select",
          "id": "option_2_style",
          "label": "Option 2 Maps To",
          "options": [
            { "value": "scandinavian", "label": "Scandinavian" },
            { "value": "mid_century", "label": "Mid-Century" },
            { "value": "boho", "label": "Boho" },
            { "value": "industrial", "label": "Industrial" }
          ],
          "default": "mid_century"
        },
        {
          "type": "text",
          "id": "option_3_text",
          "label": "Option 3 Label",
          "default": "Layered textiles & earthy tones"
        },
        {
          "type": "select",
          "id": "option_3_style",
          "label": "Option 3 Maps To",
          "options": [
            { "value": "scandinavian", "label": "Scandinavian" },
            { "value": "mid_century", "label": "Mid-Century" },
            { "value": "boho", "label": "Boho" },
            { "value": "industrial", "label": "Industrial" }
          ],
          "default": "boho"
        },
        {
          "type": "text",
          "id": "option_4_text",
          "label": "Option 4 Label",
          "default": "Raw metal & exposed materials"
        },
        {
          "type": "select",
          "id": "option_4_style",
          "label": "Option 4 Maps To",
          "options": [
            { "value": "scandinavian", "label": "Scandinavian" },
            { "value": "mid_century", "label": "Mid-Century" },
            { "value": "boho", "label": "Boho" },
            { "value": "industrial", "label": "Industrial" }
          ],
          "default": "industrial"
        }
      ]
    },
    {
      "type": "result",
      "name": "Style result",
      "settings": [
        {
          "type": "select",
          "id": "style_key",
          "label": "Style Key",
          "options": [
            { "value": "scandinavian", "label": "Scandinavian" },
            { "value": "mid_century", "label": "Mid-Century" },
            { "value": "boho", "label": "Boho" },
            { "value": "industrial", "label": "Industrial" }
          ],
          "default": "scandinavian"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Result Title",
          "default": "Scandinavian"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Result Description",
          "default": "Light woods, soft neutrals, and clean lines define your space."
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Matching Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Design style quiz",
      "blocks": [
        { "type": "question" },
        { "type": "question", "settings": { "question": "How do you like your furniture silhouettes?" } },
        { "type": "result", "settings": { "style_key": "scandinavian", "title": "Scandinavian" } },
        { "type": "result", "settings": { "style_key": "mid_century", "title": "Mid-Century Modern", "description": "Tapered legs, walnut tones, and retro-inspired curves." } },
        { "type": "result", "settings": { "style_key": "boho", "title": "Boho", "description": "Rattan, layered textiles, and warm earthy accents." } },
        { "type": "result", "settings": { "style_key": "industrial", "title": "Industrial", "description": "Raw steel, reclaimed wood, and exposed structural details." } }
      ]
    }
  ]
}
{% endschema %}
