{{ 'section-announcement-bar.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %}
sections/announcement-bar.liquid
{% endcomment %}

{%- liquid
  assign text = section.settings.text
  assign link = section.settings.link
-%}

{%- if text != blank -%}
  <div 
    id="announcement-bar--{{ section.id }}" 
    class="announcement-bar"
    data-section-id="{{ section.id }}"
    data-section-type="announcement-bar"
  >
    {%- if link != blank -%}
      <a href="{{ link }}" class="announcement-bar__link">
        {{ text | escape }}
      </a>
    {%- else -%}
      <span class="announcement-bar__text">{{ text | escape }}</span>
    {%- endif -%}
  </div>
{%- endif -%}

<style>
  #announcement-bar--{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: 'var(--accent-color)' }};
    color: {{ section.settings.text_color | default: 'var(--background)' }};
  }
</style>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Complementary shipping on orders over $250"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2B2927"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FAF9F6"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
