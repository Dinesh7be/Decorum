{{ 'section-material-finish-explorer.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %}
sections/material-finish-explorer.liquid

Filterable swatch grid. Each "material" block is a wood/fabric/finish/metal
swatch linking to the collection where matching products live. Filtering is
a plain client-side hidden-attribute toggle (decor-material-filter,
theme.js) — every swatch is server-rendered up front, so no JS templating
of markup or images is needed.
{% endcomment %}

{%- liquid
  assign space_class = ''
  if section.settings.section_space == 'top'
    assign space_class = ' mt0'
  elsif section.settings.section_space == 'bottom'
    assign space_class = ' mb0'
  elsif section.settings.section_space == 'none'
    assign space_class = ' my0'
  endif

  assign material_types = section.blocks | map: 'settings.material_type' | uniq
-%}

<section
  class="global__section{{ space_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="material-finish-explorer"
>
  <div class="grid__wrapper">
    <div class="span-12">
      {%- if section.settings.title != blank -%}
        <h2 class="section__title" style="text-align: center; margin-bottom: 1rem;">
          {{ section.settings.title | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p style="text-align: center; color: var(--text-color-light); margin-bottom: 3rem;">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <decor-material-filter>
          {%- if material_types.size > 1 -%}
            <div class="material-explorer__filters" role="group" aria-label="{{ 'sections.material_explorer.filter_group_label' | t }}">
              <button type="button" class="material-explorer__filter-btn js-material-filter-btn" data-type="all" aria-pressed="true">
                {{ 'sections.material_explorer.all_materials' | t }}
              </button>
              {%- for type in material_types -%}
                <button type="button" class="material-explorer__filter-btn js-material-filter-btn" data-type="{{ type }}" aria-pressed="false">
                  {{ type | capitalize }}
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="material-explorer__grid js-material-grid">
            {%- for block in section.blocks -%}
              {%- liquid
                assign material_collection = collections[block.settings.collection]
                assign swatch_url = material_collection.url | default: '#'
              -%}
              <a
                href="{{ swatch_url }}"
                class="material-explorer__swatch js-material-swatch"
                data-type="{{ block.settings.material_type }}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.swatch_image != blank -%}
                  <div class="material-explorer__swatch-image">
                    {%- render 'basic-responsive-image', image: block.settings.swatch_image, sizes: '120px', loading: 'lazy' -%}
                  </div>
                {%- else -%}
                  <div class="material-explorer__swatch-color" style="background-color: {{ block.settings.swatch_color | default: '#E6E1DA' }};"></div>
                {%- endif -%}
                <span class="material-explorer__swatch-name">{{ block.settings.name | escape }}</span>
                <span class="material-explorer__swatch-type">{{ block.settings.material_type }}</span>
              </a>
            {%- endfor -%}
            <p class="material-explorer__empty js-material-empty" hidden>
              {{ 'sections.material_explorer.no_matches' | t }}
            </p>
          </div>
        </decor-material-filter>
      {%- else -%}
        <p style="text-align: center; color: var(--text-color-light);">
          {{ 'sections.material_explorer.onboarding_notice' | t }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Material & finishes",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 16,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Materials & Finishes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore the woods, fabrics, and finishes across our catalog."
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section Spacing",
      "options": [
        { "value": "top", "label": "No top padding" },
        { "value": "bottom", "label": "No bottom padding" },
        { "value": "both", "label": "Standard padding" },
        { "value": "none", "label": "No padding" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "material",
      "name": "Material swatch",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Material Name",
          "default": "Solid Oak"
        },
        {
          "type": "select",
          "id": "material_type",
          "label": "Material Type",
          "options": [
            { "value": "wood", "label": "Wood" },
            { "value": "fabric", "label": "Fabric" },
            { "value": "finish", "label": "Finish" },
            { "value": "metal", "label": "Metal" },
            { "value": "stone", "label": "Stone" }
          ],
          "default": "wood"
        },
        {
          "type": "image_picker",
          "id": "swatch_image",
          "label": "Swatch Image",
          "info": "Close-up texture photo. Falls back to a flat color swatch if left blank."
        },
        {
          "type": "color",
          "id": "swatch_color",
          "label": "Fallback Swatch Color",
          "default": "#B08D57"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Matching Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Material & finishes",
      "blocks": [
        { "type": "material", "settings": { "name": "Solid Oak", "material_type": "wood" } },
        { "type": "material", "settings": { "name": "Walnut", "material_type": "wood", "swatch_color": "#5C4433" } },
        { "type": "material", "settings": { "name": "Boucle", "material_type": "fabric", "swatch_color": "#EDE7DD" } },
        { "type": "material", "settings": { "name": "Brushed Brass", "material_type": "metal", "swatch_color": "#B5A46A" } }
      ]
    }
  ]
}
{% endschema %}
