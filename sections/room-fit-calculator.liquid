{{ 'section-room-fit-calculator.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-product-listing.css' | asset_url | stylesheet_tag }}

{% comment %}
sections/room-fit-calculator.liquid

Merchant picks one collection (e.g. "Sofas"). Every product in that
collection is server-rendered up front via the standard product-listing
snippet, each wrapped with its width/depth (parsed from
product.metafields.custom.width/depth, same fields snip-product-dimensions.liquid
already reads). decor-room-fit (theme.js) only ever shows/hides those
pre-rendered cards based on the customer's room input — it never builds
product markup or images client-side.
{% endcomment %}

{%- liquid
  assign space_class = ''
  if section.settings.section_space == 'top'
    assign space_class = ' mt0'
  elsif section.settings.section_space == 'bottom'
    assign space_class = ' mb0'
  elsif section.settings.section_space == 'none'
    assign space_class = ' my0'
  endif

  assign fit_collection = collections[section.settings.collection]
-%}

<section
  class="global__section{{ space_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="room-fit-calculator"
>
  <div class="grid__wrapper">
    <div class="span-12">
      {%- if section.settings.title != blank -%}
        <h2 class="section__title" style="text-align: center; margin-bottom: 1rem;">
          {{ section.settings.title | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p style="text-align: center; color: var(--text-color-light); margin-bottom: 3rem;">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

      {%- if fit_collection != blank -%}
        <decor-room-fit data-clearance="{{ section.settings.clearance | default: 0 }}">
          <form class="room-fit__form js-room-fit-form">
            <div class="room-fit__field">
              <label for="RoomFitWidth-{{ section.id }}">{{ 'sections.room_fit.width_label' | t }}</label>
              <input type="number" min="1" step="0.5" id="RoomFitWidth-{{ section.id }}" class="js-room-fit-width" required>
            </div>
            <div class="room-fit__field">
              <label for="RoomFitDepth-{{ section.id }}">{{ 'sections.room_fit.depth_label' | t }}</label>
              <input type="number" min="1" step="0.5" id="RoomFitDepth-{{ section.id }}" class="js-room-fit-depth" required>
            </div>
            <div class="room-fit__field">
              <label for="RoomFitUnit-{{ section.id }}">{{ 'sections.room_fit.unit_label' | t }}</label>
              <select id="RoomFitUnit-{{ section.id }}" class="js-room-fit-unit">
                <option value="in">{{ 'sections.room_fit.unit_in' | t }}</option>
                <option value="cm">{{ 'sections.room_fit.unit_cm' | t }}</option>
              </select>
            </div>
            <button type="submit" class="btn">{{ 'sections.room_fit.submit' | t }}</button>
          </form>

          {%- capture match_template -%}
            {{ 'sections.room_fit.match_count' | t: count: '{count}' }}
          {%- endcapture -%}
          <p
            class="room-fit__status js-room-fit-status"
            aria-live="polite"
            data-match-template="{{ match_template | strip | escape }}"
            data-empty-text="{{ 'sections.room_fit.no_matches' | t | escape }}"
          ></p>

          <div class="room-fit__grid js-room-fit-grid">
            {%- for product in fit_collection.products limit: 24 -%}
              {%- liquid
                assign raw_width = product.metafields.custom.width.value | default: product.metafields.custom.width
                assign p_width = '' | append: raw_width | default: '0' | remove: '"' | strip

                assign raw_depth = product.metafields.custom.depth.value | default: product.metafields.custom.depth
                assign p_depth = '' | append: raw_depth | default: '0' | remove: '"' | strip
              -%}
              <div class="room-fit__item js-room-fit-item" data-width="{{ p_width }}" data-depth="{{ p_depth }}" hidden>
                {%- render 'product-listing', product: product, loading: 'lazy' -%}
              </div>
            {%- endfor -%}
          </div>
        </decor-room-fit>
      {%- else -%}
        <p style="text-align: center; color: var(--text-color-light);">
          {{ 'sections.room_fit.onboarding_notice' | t }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Room fit calculator",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Will It Fit Your Room?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Enter your space and we'll surface pieces sized to match."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Search",
      "info": "Products must have Width/Depth metafields (product.metafields.custom.width / .depth) set to show accurate matches."
    },
    {
      "type": "range",
      "id": "clearance",
      "label": "Required Clearance",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 6,
      "unit": "in",
      "info": "Subtracted from the room dimensions before matching, to leave walking space."
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section Spacing",
      "options": [
        { "value": "top", "label": "No top padding" },
        { "value": "bottom", "label": "No bottom padding" },
        { "value": "both", "label": "Standard padding" },
        { "value": "none", "label": "No padding" }
      ],
      "default": "both"
    }
  ],
  "presets": [
    {
      "name": "Room fit calculator"
    }
  ]
}
{% endschema %}
