{% comment %}
sections/faq.liquid
{% endcomment %}

{{ 'section-faq.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign heading = section.settings.title
  assign space_class = ''
  if section.settings.section_space == 'top'
    assign space_class = ' mt0'
  elsif section.settings.section_space == 'bottom'
    assign space_class = ' mb0'
  elsif section.settings.section_space == 'none'
    assign space_class = ' my0'
  endif
-%}

<section 
  class="global__section faq-section{{ space_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="faq-accordion"
>
  <div class="grid__wrapper narrow faq__container">
    {%- if heading != blank -%}
      <div class="span-12 faq__header">
        <h2 class="faq__title">{{ heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="span-12 faq__accordion-list">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div 
            class="faq__accordion-item" 
            {{ block.shopify_attributes }}
          >
            <details {% if block.settings.open_default %}open{% endif %} class="faq__accordion-details">
              <summary class="faq__accordion-summary">
                <span>{{ block.settings.question | escape }}</span>
                <span class="faq__accordion-icon">&plus;</span>
              </summary>
              <div class="rte faq__accordion-content">
                {{ block.settings.answer }}
              </div>
            </details>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Onboarding state (B3) -->
        {%- for i in (1..3) -%}
          {%- liquid
            case i
              when 1
                assign q = 'sections.faq.q1' | t
                assign a = 'sections.faq.a1' | t
              when 2
                assign q = 'sections.faq.q2' | t
                assign a = 'sections.faq.a2' | t
              when 3
                assign q = 'sections.faq.q3' | t
                assign a = 'sections.faq.a3' | t
            endcase
          -%}
          <div class="faq__accordion-item">
            <details class="faq__accordion-details">
              <summary class="faq__accordion-summary">
                <span>{{ q }}</span>
                <span class="faq__accordion-icon">&plus;</span>
              </summary>
              <div class="rte faq__accordion-content">
                {{ a }}
              </div>
            </details>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ / Accordions",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section Spacing",
      "options": [
        { "value": "top", "label": "No top padding" },
        { "value": "bottom", "label": "No bottom padding" },
        { "value": "both", "label": "Standard padding" },
        { "value": "none", "label": "No padding" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Q&A Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Add your question here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Add details or answer guidelines here.</p>"
        },
        {
          "type": "checkbox",
          "id": "open_default",
          "label": "Open by default",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ / Accordions",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day return window on all small decor. Large custom furniture items are subject to a 15% restocking fee.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you customize sizes?",
            "answer": "<p>Yes! Contact our custom studio team for custom wood finishes, fabric selections, and modular configurations.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
