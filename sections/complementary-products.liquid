{% comment %}
sections/complementary-products.liquid
{% endcomment %}
{{ 'section-complementary-products.css' | asset_url | stylesheet_tag: preload: true }}

<div 
  class="js-complementary-products" 
  data-product-id="{{ product.id }}" 
  data-limit="4"
  data-section-id="{{ section.id }}" 
  data-section-type="complementary-products"
>
  {%- if recommendations.performed? and recommendations.products_count > 0 -%}
    <div class="complementary-products__wrapper">
      <h3 class="complementary-products__title">
        {{ section.settings.heading | escape }}
      </h3>
      <div class="complementary-products__list">
        {%- for product in recommendations.products -%}
          <div class="complementary-product__item">
            <div class="complementary-product__info">
              <a href="{{ product.url }}" class="complementary-product__image-link">
                {%- if product.featured_media != blank -%}
                  <img src="{{ product.featured_media | image_url: width: 120, height: 120, crop: 'center' }}" alt="{{ product.title | escape }}" width="70" height="70" loading="lazy">
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </a>
              <div class="complementary-product__meta">
                <h4 class="complementary-product__title">
                  <a href="{{ product.url }}" class="complementary-product__title-link">{{ product.title }}</a>
                </h4>
                <span class="complementary-product__price">
                  {{ product.price | money }}
                </span>
              </div>
            </div>
            
            {%- if product.available -%}
              <decor-cart-form class="complementary-product__form">
                {%- form 'product', product -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" name="add" class="btn btn--secondary complementary-product__add-button" aria-label="Add to cart" style="padding: 0.8rem; min-height: unset; border-radius: 50%;">
                    {% render 'snip-icons', icon: 'cart', size: '14px' %}
                  </button>
                {%- endform -%}
              </decor-cart-form>
            {%- else -%}
              <button class="btn btn--secondary complementary-product__add-button" disabled style="padding: 0.8rem; min-height: unset; border-radius: 50%; opacity: 0.5;">
                &times;
              </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- elsif request.design_mode -%}
    <div class="complementary-products__wrapper">
      <h3 class="complementary-products__title">
        {{ section.settings.heading | escape }}
      </h3>
      <div class="complementary-products__list">
        {%- for i in (1..3) -%}
          {%- capture svg_index -%}{% cycle 1, 2, 3 %}{%- endcapture -%}
          <div class="complementary-product__item">
            <div class="complementary-product__info">
              <div class="complementary-product__image-link">
                {{ 'product-' | append: svg_index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="complementary-product__meta">
                <h4 class="complementary-product__title">
                  <span class="complementary-product__title-link">Mock Product {{ i }}</span>
                </h4>
                <span class="complementary-product__price">
                  $49.00
                </span>
              </div>
            </div>
            <button type="button" class="btn btn--secondary complementary-product__add-button" style="padding: 0.8rem; min-height: unset; border-radius: 50%;">
              {% render 'snip-icons', icon: 'cart', size: '14px' %}
            </button>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Complementary products",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pairs well with"
    }
  ],
  "presets": [
    {
      "name": "Complementary products"
    }
  ]
}
{% endschema %}
