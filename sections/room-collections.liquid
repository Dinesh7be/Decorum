{{ 'section-room-collections.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %}
sections/room-collections.liquid
{% endcomment %}

{%- liquid
  assign heading = section.settings.title
  assign space_class = ''
  if section.settings.section_space == 'top'
    assign space_class = ' mt0'
  elsif section.settings.section_space == 'bottom'
    assign space_class = ' mb0'
  elsif section.settings.section_space == 'none'
    assign space_class = ' my0'
  endif
-%}

<section 
  class="global__section{{ space_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="room-collections"
>
  {%- if heading != blank -%}
    <div class="grid__wrapper">
      <div class="span-12 room-collections__header">
        <h2>{{ heading | escape }}</h2>
      </div>
    </div>
  {%- endif -%}

  <div class="grid__wrapper">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- liquid
          case section.blocks.size
            when 1
              assign col_span = 'span-12'
            when 2
              assign col_span = 'span-6'
            else
              assign col_span = 'span-4'
          endcase

          assign collection = collections[block.settings.collection]
          assign title = block.settings.title | default: collection.title
          assign image = block.settings.image | default: collection.featured_image
          assign url = block.settings.link | default: collection.url
        -%}

        <div class="{{ col_span }} sm-span-12" {{ block.shopify_attributes }}>
          <a href="{{ url | default: routes.all_products_collection_url }}" class="room-card__wrapper">
            <div class="room-card__image">
              {%- if image != blank -%}
                {%- render 'basic-responsive-image', 
                  image: image, 
                  sizes: '(min-width: 740px) 33vw, 100vw',
                  loading: 'lazy',
                  custom_aspect_ratio: '4:3'
                -%}
              {%- else -%}
                {%- render 'onboard-collection', index: forloop.index, aspect_ratio: '4:3' -%}
              {%- endif -%}
            </div>
            
            <div class="room-card__content">
              <h3 class="room-card__title">{{ title }}</h3>
              <span class="room-card__link-text">
                {{ 'sections.room_collections.explore' | t }} 
                {% render 'snip-icons', icon: 'chevron-right', size: '10px' %}
              </span>
            </div>
          </a>
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Onboarding state (SEC-005) -->
      {%- for i in (1..3) -%}
        {%- liquid
          case i
            when 1
              assign title = 'Living Room'
            when 2
              assign title = 'Bedroom'
            when 3
              assign title = 'Home Office'
          endcase
        -%}
        <div class="span-4 sm-span-12">
          <a href="#" class="room-card__wrapper">
            <div class="room-card__image">
              {%- render 'onboard-collection', index: i, aspect_ratio: '4:3' -%}
            </div>
            <div class="room-card__content">
              <h3 class="room-card__title">{{ title }}</h3>
              <span class="room-card__link-text">
                {{ 'sections.room_collections.explore' | t }}
                {% render 'snip-icons', icon: 'chevron-right', size: '10px' %}
              </span>
            </div>
          </a>
        </div>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Room collections",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop by room"
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section Spacing",
      "options": [
        { "value": "top", "label": "No top padding" },
        { "value": "bottom", "label": "No bottom padding" },
        { "value": "both", "label": "Standard padding" },
        { "value": "none", "label": "No padding" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "room",
      "name": "Room Grid Item",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override Room Title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Room Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom URL (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Room collections",
      "blocks": [
        { "type": "room", "settings": { "title": "Living Room" } },
        { "type": "room", "settings": { "title": "Bedroom" } },
        { "type": "room", "settings": { "title": "Office" } }
      ]
    }
  ]
}
{% endschema %}
