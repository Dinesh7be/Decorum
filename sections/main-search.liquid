{{ 'section-main-collection.css' | asset_url | stylesheet_tag }}
{{ 'section-main-search.css' | asset_url | stylesheet_tag }}

{% comment %}
sections/main-search.liquid
{% endcomment %}

<section 
  class="global__section" 
  data-section-id="{{ section.id }}" 
  data-section-type="main-search"
>
  <div class="grid__wrapper search__header" style="margin-top: -2rem;">
    <div class="span-12">
      <form action="{{ routes.search_url }}" method="get" role="search" class="search__form-wrapper">
        <input 
          type="search" 
          name="q" 
          value="{{ search.terms | escape }}" 
          placeholder="{{ 'general.search.placeholder' | t }}"
          class="search__input"
        >
        <button type="submit" class="search__submit-btn" aria-label="{{ 'general.search.search' | t }}">
          {% render 'snip-icons', icon: 'search', size: '18px' %}
        </button>
      </form>
    </div>
  </div>

  <div class="grid__wrapper">
    <div class="span-12">
      {%- if search.performed -%}
        {%- paginate search.results by 12 -%}
          {%- if search.results.size > 0 -%}
            <p class="search__results-count">
              {{ 'general.search.results_count' | t: count: search.results_count, terms: search.terms }}
            </p>

            <div class="grid__wrapper collection__layout">
              <!-- Sidebar: Filters (AJAX enabled with decor-filters) -->
              <div class="span-3 sm-span-12">
                <decor-filters class="collection__sidebar">
                  <form id="SearchFiltersForm" class="filter-form">
                    <input type="hidden" name="q" value="{{ search.terms | escape }}">
                    <input type="hidden" name="options[prefix]" value="last">
                    
                    <!-- Active filter details -->
                    <div id="ActiveFilters" class="active-filters">
                      {%- for filter in search.filters -%}
                        {%- for value in filter.active_values -%}
                          <a 
                            href="{{ value.url_to_remove }}" 
                            class="btn btn--secondary active-filters__remove-btn"
                          >
                            {{ filter.label }}: {{ value.label }} &times;
                          </a>
                        {%- endfor -%}
                        {%- if filter.type == "price_range" -%}
                          {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
                            <a 
                              href="{{ filter.url_to_remove }}" 
                              class="btn btn--secondary active-filters__remove-btn"
                            >
                              {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}$0{%- endif -%} - 
                              {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%} &times;
                            </a>
                          {%- endif -%}
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                    <!-- Filters Loop -->
                    {%- if search.filters.size > 0 -%}
                      {%- for filter in search.filters -%}
                        <div class="filter-group">
                          <h3 class="filter-group__title">{{ filter.label }}</h3>
                          
                          {%- case filter.type -%}
                            {%- when 'list' -%}
                              <ul class="filter-group__list" role="list">
                                {%- for value in filter.values -%}
                                  <li class="filter-group__item">
                                    <input 
                                      type="checkbox" 
                                      name="{{ value.param_name }}" 
                                      value="{{ value.value }}" 
                                      id="Filter-{{ filter.label | handle }}-{{ forloop.index }}"
                                      class="filter-group__checkbox"
                                      {% if value.active %}checked{% endif %}
                                      {% if value.count == 0 and value.active == false %}disabled{% endif %}
                                    >
                                    <label for="Filter-{{ filter.label | handle }}-{{ forloop.index }}">
                                      {{ value.label }} ({{ value.count }})
                                    </label>
                                  </li>
                                {%- endfor -%}
                              </ul>

                            {%- when 'price_range' -%}
                              <div class="filter-group__price-range">
                                <div class="filter-group__price-range-col">
                                  <label for="Filter-Price-Min">{{ 'sections.collection.min' | t }}</label>
                                  <input 
                                    type="number" 
                                    name="{{ filter.min_value.param_name }}" 
                                    id="Filter-Price-Min"
                                    placeholder="0"
                                    value="{{ filter.min_value.value | divided_by: 100 }}"
                                    min="0"
                                    max="{{ filter.range_max | divided_by: 100 }}"
                                  >
                                </div>
                                <span class="filter-group__price-range-to">{{ 'sections.collection.to' | t }}</span>
                                <div class="filter-group__price-range-col">
                                  <label for="Filter-Price-Max">{{ 'sections.collection.max' | t }}</label>
                                  <input 
                                    type="number" 
                                    name="{{ filter.max_value.param_name }}" 
                                    id="Filter-Price-Max"
                                    placeholder="{{ filter.range_max | divided_by: 100 }}"
                                    value="{{ filter.max_value.value | divided_by: 100 }}"
                                    min="0"
                                    max="{{ filter.range_max | divided_by: 100 }}"
                                  >
                                </div>
                              </div>
                          {%- endcase -%}
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  </form>
                </decor-filters>
              </div>

              <!-- Product Grid Container -->
              <div id="ProductGridContainer" class="span-9 sm-span-12">
                <div class="grid__wrapper edge search__results-grid">
                  {%- for item in search.results -%}
                    {%- if item.object_type == 'product' -%}
                      <div class="span-4 sm-span-6 grid-item">
                        {%- render 'product-listing', product: item -%}
                      </div>
                    {%- else -%}
                      <!-- Article or Page result -->
                      <div class="span-4 sm-span-6 grid-item search__item-card">
                        <div>
                          <span class="search__item-type">{{ item.object_type }}</span>
                          <h3 class="search__item-title">
                            <a href="{{ item.url }}">{{ item.title }}</a>
                          </h3>
                          <p class="search__item-excerpt">{{ item.content | strip_html | truncatewords: 20 }}</p>
                        </div>
                        <a href="{{ item.url }}" class="search__item-link">{{ 'general.search.read_more' | t }}</a>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              </div>
            </div>

            {%- render 'pagination', paginate: paginate -%}
          {%- else -%}
            <p class="search__no-results">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
            
            <div class="grid__wrapper edge search__results-grid">
              {%- for i in (1..3) -%}
                <div class="span-4 sm-span-6 grid-item">
                  {%- render 'onboard-product', index: i -%}
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        {%- endpaginate -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Search Results",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Page Title",
      "default": true
    }
  ]
}
{% endschema %}
