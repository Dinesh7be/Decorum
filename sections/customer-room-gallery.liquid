{{ 'section-customer-room-gallery.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %}
sections/customer-room-gallery.liquid

UGC wall of customer-submitted photos. Pure CSS masonry (column layout) —
no JS needed. Each photo optionally links to the product shown in it.
{% endcomment %}

{%- liquid
  assign space_class = ''
  if section.settings.section_space == 'top'
    assign space_class = ' mt0'
  elsif section.settings.section_space == 'bottom'
    assign space_class = ' mb0'
  elsif section.settings.section_space == 'none'
    assign space_class = ' my0'
  endif
-%}

<section
  class="global__section{{ space_class }}"
  data-section-id="{{ section.id }}"
  data-section-type="customer-room-gallery"
>
  <div class="grid__wrapper">
    <div class="span-12">
      {%- if section.settings.title != blank -%}
        <h2 class="section__title" style="text-align: center; margin-bottom: 1rem;">
          {{ section.settings.title | escape }}
        </h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p style="text-align: center; color: var(--text-color-light); margin-bottom: 3rem;">
          {{ section.settings.subheading | escape }}
        </p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="room-gallery__grid">
          {%- for block in section.blocks -%}
            {%- liquid
              assign tagged_product = all_products[block.settings.product]
              assign link_url = tagged_product.url | default: block.settings.instagram_url | default: '#'
            -%}
            <a href="{{ link_url }}" class="room-gallery__item" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                {%- render 'basic-responsive-image', image: block.settings.image, sizes: '(min-width: 740px) 25vw, 50vw', loading: 'lazy' -%}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
              {%- if block.settings.customer_name != blank or block.settings.instagram_handle != blank -%}
                <span class="room-gallery__caption">
                  {%- if block.settings.customer_name != blank -%}
                    <span class="room-gallery__name">{{ block.settings.customer_name | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.instagram_handle != blank -%}
                    <span class="room-gallery__handle">{{ block.settings.instagram_handle | escape }}</span>
                  {%- endif -%}
                </span>
              {%- endif -%}
            </a>
          {%- endfor -%}
        </div>
      {%- else -%}
        <p style="text-align: center; color: var(--text-color-light);">
          {{ 'sections.room_gallery.onboarding_notice' | t }}
        </p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Customer room gallery",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 20,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Styled By You"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real customer homes, real Decorum pieces. Tag us to be featured."
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section Spacing",
      "options": [
        { "value": "top", "label": "No top padding" },
        { "value": "bottom", "label": "No bottom padding" },
        { "value": "both", "label": "Standard padding" },
        { "value": "none", "label": "No padding" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Customer photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Photo"
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer Name",
          "default": "Customer Name"
        },
        {
          "type": "text",
          "id": "instagram_handle",
          "label": "Instagram Handle",
          "default": "@handle"
        },
        {
          "type": "url",
          "id": "instagram_url",
          "label": "Instagram Post Link (optional)"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Featured Product (optional)",
          "info": "If set, the photo links to this product instead of the Instagram URL."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer room gallery",
      "blocks": [
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
