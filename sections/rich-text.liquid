{{ 'section-rich-text.css' | asset_url | stylesheet_tag: preload: true }}

{% comment %}
sections/rich-text.liquid
{% endcomment %}

{%- liquid
  assign space_class = ''
  if section.settings.section_space == 'top'
    assign space_class = ' mt0'
  elsif section.settings.section_space == 'bottom'
    assign space_class = ' mb0'
  elsif section.settings.section_space == 'none'
    assign space_class = ' my0'
  endif
-%}

<section 
  class="global__section{{ space_class }} rich-text-section"
  data-section-id="{{ section.id }}"
  data-section-type="rich-text"
  style="background-color: {{ section.settings.bg_color | default: 'transparent' }}; text-align: {{ section.settings.align | default: 'center' }};"
>
  <div class="grid__wrapper rich-text__grid">
    <div class="span-8 push-2 sm-span-12">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              <p class="rich-text__subheading" {{ block.shopify_attributes }}>
                {{ block.settings.subheading | escape }}
              </p>
            {%- endif -%}

          {%- when 'heading' -%}
            {%- if block.settings.heading != blank -%}
              <h2 class="rich-text__heading" {{ block.shopify_attributes }}>
                {{ block.settings.heading | escape }}
              </h2>
            {%- endif -%}

          {%- when 'text' -%}
            {%- if block.settings.text != blank -%}
              <div class="rich-text__text rte" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>
            {%- endif -%}

          {%- when 'button' -%}
            {%- if block.settings.button_text != blank and block.settings.button_url != blank -%}
              <div class="rich-text__btn-container" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.button_url }}" class="btn">
                  {{ block.settings.button_text | escape }}
                </a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Rich Text",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "align",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "select",
      "id": "section_space",
      "label": "Section Spacing",
      "options": [
        { "value": "top", "label": "No top padding" },
        { "value": "bottom", "label": "No bottom padding" },
        { "value": "both", "label": "Standard padding" },
        { "value": "none", "label": "No padding" }
      ],
      "default": "both"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Minimal aesthetics. Premium design."
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Our Philosophy"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>We believe in spaces that feel calm, uncluttered, and inspired by organic materials. Every design is built to stand the test of time.</p>"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Label",
          "default": "Read Our Story"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Rich Text",
      "blocks": [
        { "type": "subheading" },
        { "type": "heading" },
        { "type": "text" }
      ]
    }
  ]
}
{% endschema %}
